{
  "name": "actimeet",
  "version": "0.1.0",
  "private": true,
  "description": "Connect through activities. Find your spark.",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules",
    "db:reset": "cd packages/database && ./setup.sh reset",
    "db:migrate": "cd packages/database && ./setup.sh migrate",
    "db:seed": "cd packages/database && ./setup.sh seed",
    "db:studio": "cd packages/database && npx drizzle-kit studio"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
