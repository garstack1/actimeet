# ActiMeet Environment Variables
# Copy this to .env.local and fill in your values

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://actimeet:actimeet_dev_password@localhost:5432/actimeet_dev"
DB_HOST=localhost
DB_PORT=5432
DB_NAME=actimeet_dev
DB_USER=actimeet
DB_PASSWORD=actimeet_dev_password

# ===========================================
# AUTHENTICATION
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ===========================================
# STRIPE
# ===========================================
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ===========================================
# EMAIL (SendGrid / Resend)
# ===========================================
EMAIL_FROM="ActiMeet <hello@actimeet.ie>"
SENDGRID_API_KEY=SG...
# Or for Resend:
# RESEND_API_KEY=re_...

# ===========================================
# PUSH NOTIFICATIONS (OneSignal)
# ===========================================
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# ===========================================
# FILE STORAGE (Cloudflare R2 / AWS S3)
# ===========================================
S3_BUCKET=actimeet-uploads
S3_REGION=eu-west-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=  # For R2: https://<account>.r2.cloudflarestorage.com

# CDN URL for serving images
CDN_URL=https://cdn.actimeet.ie

# ===========================================
# SEARCH (Meilisearch / Algolia)
# ===========================================
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterKey
# Or for Algolia:
# ALGOLIA_APP_ID=
# ALGOLIA_API_KEY=

# ===========================================
# GOOGLE MAPS (for venue autocomplete)
# ===========================================
GOOGLE_MAPS_API_KEY=

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Logging
LOG_LEVEL=debug

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
